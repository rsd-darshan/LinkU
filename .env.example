# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development


# Database
# Matches `docker-compose.yml` (Postgres on host port 5433)
DATABASE_URL=postgresql://linku:linku@localhost:5433/linku

# Clerk (add your LAN URL in Clerk Dashboard allowed origins to use app from phone/other device)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up

# Payments (optional: only if Stripe flow is enabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# S3 (optional: leave empty for local uploads only)
S3_REGION=us-east-1
S3_BUCKET_NAME=linku-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public URL for uploaded files (e.g. https://linku-assets.s3.us-east-1.amazonaws.com)
S3_PUBLIC_BASE_URL=

# Optional realtime (Pusher)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Optional mentor matching tuning
# MATCH_WEIGHT_MAJOR=30
# MATCH_WEIGHT_COUNTRY=15
# MATCH_WEIGHT_GPA=25
# MATCH_WEIGHT_UNIVERSITY_CAP=20
# MATCH_WEIGHT_VERIFIED_BADGE=5
# MATCH_WEIGHT_RATING=5

# Agora (video calling)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# LinkU-AI (admissions intelligence)
OPENROUTER_API_KEY=
LINKU_AI_CRON_SECRET=
# Optional: scoring weights (defaults: academic 40, eca 25, major 15, essay 10, context 10)
# LINKU_AI_WEIGHT_ACADEMIC=40
# LINKU_AI_WEIGHT_ECA=25
# LINKU_AI_WEIGHT_MAJOR=15
# LINKU_AI_WEIGHT_ESSAY=10
# LINKU_AI_WEIGHT_CONTEXT=10

